# Copy this file to `.env.local`.
# By default the frontend runs against the mock repository so the MVP is usable
# without external services. Switch to `supabase` after backend wiring is ready.

VITE_APP_BASE_URL="https://mybiz.ai.kr"
VITE_DATA_PROVIDER="mock"

# Supabase
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Gemini browser-key mode for MVP/demo environments only.
# For production keep GEMINI_API_KEY on a server or edge function and proxy calls.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_API_KEY="SERVER_SIDE_ONLY_IF_USING_PROXY"

# PortOne V2 webhook secret from the PortOne admin console.
PORTONE_WEBHOOK_SECRET="YOUR_PORTONE_WEBHOOK_SECRET"
