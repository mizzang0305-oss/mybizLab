VITE_APP_BASE_URL=https://mybiz.ai.kr
VITE_DATA_PROVIDER=local

# Optional demo-only browser login. Leave VITE_DEMO_ADMIN_PASSWORD empty to disable
# the email/password demo form and use the one-click demo access button instead.
VITE_DEMO_ADMIN_EMAIL=demo@mybizlab.ai
VITE_DEMO_ADMIN_PASSWORD=

# Firebase browser config for future Firebase adapter usage.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Billing / payment
NEXT_PUBLIC_PORTONE_STORE_ID=store-v2-your-store-id
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-your-channel-key
VITE_PORTONE_STORE_ID=store-v2-your-store-id
VITE_PORTONE_CHANNEL_KEY=channel-key-your-channel-key
PORTONE_API_SECRET=YOUR_PORTONE_API_SECRET
PORTONE_WEBHOOK_SECRET=YOUR_PORTONE_WEBHOOK_SECRET
PORTONE_STORE_ID=store-v2-your-store-id
PORTONE_CHANNEL_KEY=channel-key-your-channel-key

# Legacy Supabase integration used by some existing admin flows. Optional when
# VITE_DATA_PROVIDER=local.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# AI providers
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_API_KEY=SERVER_SIDE_ONLY_IF_USING_PROXY
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini
