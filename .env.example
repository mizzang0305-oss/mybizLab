# Copy this file to `.env.local` for local Vite work.
# For `/api/*` routes, use `vercel dev` locally and register the same variables in
# Vercel Project Settings > Environment Variables for Development, Preview, and Production.

# Public browser envs bundled into the Vite client.
VITE_APP_BASE_URL="https://mybiz.ai.kr"
VITE_PORTONE_STORE_ID="store-v2-your-store-id"
VITE_PORTONE_CHANNEL_KEY="channel-key-your-channel-key"
VITE_DATA_PROVIDER="mock"

# Supabase
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Gemini browser-key mode for MVP/demo environments only.
# For production keep GEMINI_API_KEY on a server or edge function and proxy calls.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_API_KEY="SERVER_SIDE_ONLY_IF_USING_PROXY"

# PortOne server-only envs. Never expose these with the VITE_ prefix.
PORTONE_V2_API_SECRET="YOUR_PORTONE_V2_API_SECRET"
PORTONE_WEBHOOK_SECRET="YOUR_PORTONE_WEBHOOK_SECRET"
