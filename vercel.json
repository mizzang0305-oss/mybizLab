{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/api/public/store",
      "dest": "/api/public?resource=store"
    },
    {
      "src": "/api/public/inquiry-form",
      "dest": "/api/public?resource=inquiry-form"
    },
    {
      "src": "/api/public/consultation-form",
      "dest": "/api/public?resource=consultation-form"
    },
    {
      "src": "/api/public/visitor-session",
      "dest": "/api/public?resource=visitor-session"
    },
    {
      "src": "/api/public/inquiry",
      "dest": "/api/public?resource=inquiry"
    },
    {
      "src": "/api/public/consultation",
      "dest": "/api/public?resource=consultation"
    },
    {
      "src": "/api/public/reservation",
      "dest": "/api/public?resource=reservation"
    },
    {
      "src": "/api/public/waiting",
      "dest": "/api/public?resource=waiting"
    },
    {
      "src": "/api/public/order",
      "dest": "/api/public?resource=order"
    },
    {
      "src": "/api/public/order-customer",
      "dest": "/api/public?resource=order-customer"
    },
    {
      "src": "/api/public/order-payment-checkout",
      "dest": "/api/public?resource=order-payment-checkout"
    },
    {
      "src": "/api/public/order-payment-verify",
      "dest": "/api/public?resource=order-payment-verify"
    },
    {
      "src": "/api/merchant/order-event",
      "dest": "/api/merchant?resource=order-event"
    },
    {
      "src": "/api/admin/platform/(.*)",
      "dest": "/api/admin?resource=$1"
    },
    {
      "src": "/api/public/platform/homepage",
      "dest": "/api/public?resource=platform-homepage"
    },
    {
      "src": "/api/public/platform/pricing",
      "dest": "/api/public?resource=platform-pricing"
    },
    {
      "src": "/api/public/platform/announcements",
      "dest": "/api/public?resource=platform-announcements"
    },
    {
      "src": "/api/public/platform/board-posts",
      "dest": "/api/public?resource=platform-board-posts"
    },
    {
      "src": "/api/public/platform/popups",
      "dest": "/api/public?resource=platform-popups"
    },
    {
      "src": "/api/public/platform/banners",
      "dest": "/api/public?resource=platform-banners"
    },
    {
      "src": "/api/public/platform/chrome",
      "dest": "/api/public?resource=platform-chrome"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
